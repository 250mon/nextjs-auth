# Docker Compose Environment Variables — prod
# This file is automatically loaded by docker-compose.yml
#
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# For dev, use dev.env.example instead — dev and prod need somewhat
# different values for several of these (base path, CORS origins,
# database), so don't just reuse this file for dev.

# Next.js Base Path
# The base path for the application (default: /auth)
# NEXT_PUBLIC_BASE_PATH=/auth

# Database Configuration
# PostgreSQL connection string for the shared prod instance (REQUIRED)
# Format: postgresql://user:password@host:port/database
POSTGRES_URL=postgresql://user:password@host:5432/database

# Database SSL
# Set to 'true' to enable SSL for database connections (default: false)
DATABASE_SSL=false

# Auth configuration
# NextAuth secret key (generate a new one for production!)
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me
# Trust host header (needed behind a reverse proxy, e.g. danaul-caddy)
AUTH_TRUST_HOST=true

# REST API JWT secrets (REQUIRED — jwt-service.ts falls back to an insecure
# hardcoded default if unset, so make sure these are actually set for real prod)
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too

# CORS — comma-separated, specific domains (not *)
ALLOWED_ORIGINS="https://yourdomain.com,https://app.yourdomain.com"

# Bootstrap admin — if no super admin exists yet, both must be set to
# auto-create the first one on startup (forced to change password on first
# login). See scripts/bootstrap-admin.mjs. Leave unset once you've created
# your first admin — the script skips whenever a super admin already exists.
# BOOTSTRAP_ADMIN_EMAIL=admin@yourdomain.com
# BOOTSTRAP_ADMIN_PASSWORD=change-me
