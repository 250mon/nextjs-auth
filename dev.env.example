# Docker Compose Environment Variables — dev profile
#
# Copy this file to .env when running `docker-compose --profile dev up`:
#   cp dev.env.example .env
#
# For the prod profile, use .env.example instead.

# Host port mapping for the dev container (default: 13203:3000)
APP_PORT=13203

# Next.js Base Path — usually left unset for local dev (served at /)
# NEXT_PUBLIC_BASE_PATH=

# Auth configuration
# NextAuth secret key
AUTH_SECRET=change-me
AUTH_TRUST_HOST=true

# CORS
ALLOWED_ORIGINS=http://localhost:13203

# Local dev database — auth-app-dev talks to the `postgres` service defined
# in docker-compose.yml (dev profile only), not the shared prod instance.
# POSTGRES_URL/DATABASE_SSL are constructed by docker-compose.yml itself for
# this profile, not read from here. These are optional overrides; commented
# values match the `postgres` service's own defaults.
# DEV_POSTGRES_USER=postgres
# DEV_POSTGRES_PASSWORD=postgres
# DEV_POSTGRES_DB=danaul_auth
#
# On a fresh volume (no tables yet), scripts/docker-auto-seed.mjs creates the
# schema and the two sample users automatically before `pnpm dev` starts — no
# need to hit GET /seed yourself unless you want to reset back to that state.

# Hot reload — polling-based file watching (needed under Docker on some hosts)
WATCHPACK_POLLING=true
CHOKIDAR_USEPOLLING=true

# Debug logging (e.g. log DB queries)
DEBUG=postgres:*
