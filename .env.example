# Docker Compose Environment Variables
# This file is automatically loaded by docker-compose.yml
# Variables here can be referenced in docker-compose.yml using ${VARIABLE_NAME}
#
# Copy this file to .env and fill in real values:
#   cp .env.example .env

# Application Port
# Port mapping: host:container (default: 13203:3000)
APP_PORT=13203

# Next.js Base Path
# The base path for the application (default: /auth)
# NEXT_PUBLIC_BASE_PATH=/auth

# Database Configuration
# PostgreSQL connection string (REQUIRED)
# Format: postgresql://user:password@host:port/database
POSTGRES_URL=postgresql://user:password@host:5432/database

# Database SSL
# Set to 'true' to enable SSL for database connections (default: false)
DATABASE_SSL=false

# Auth configuration
# NextAuth secret key (generate a new one for production!)
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me
# Trust host header (set to true when behind a proxy)
AUTH_TRUST_HOST=true

# For development
ALLOWED_ORIGINS=http://localhost:3000
# For production
#ALLOWED_ORIGINS="https://yourdomain.com,https://app.yourdomain.com"
